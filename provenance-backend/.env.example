# ─────────────────────────────────────────────
# PROVENANCE BACKEND — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your keys
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# AudD API — song identification
# Get your key at https://dashboard.audd.io
AUDD_API_KEY=your_audd_api_key_here

# Spotify Web API — metadata and artist info
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Python audio analysis service (local)
# This runs alongside the Node server
PYTHON_SERVICE_URL=http://localhost:5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: YouTube Data API (for YouTube link resolution)
# https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here
